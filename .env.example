BOT_TOKEN=your_bot_token_here

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=vpnbot
POSTGRES_USER=vpnbot
POSTGRES_PASSWORD=your_secure_password

# 3x-ui (панель версии 3.x, например 3.4.2).
# Рекомендуемый способ авторизации — Bearer API-токен:
# Settings → Security → API Token → Create. Токен показывается один раз —
# сохраните его сразу в THREEXUI_API_TOKEN. Если токен задан, логин/пароль
# ниже не используются вообще (и CSRF не нужен).
THREEXUI_URL=https://your-server.com:2053
THREEXUI_USERNAME=admin
THREEXUI_PASSWORD=your_3xui_password
THREEXUI_API_TOKEN=
THREEXUI_SUB_PORT=2096

# ID инбаундов 3x-ui, в которые выдаётся клиент. Можно указать несколько через запятую,
# тогда одному клиенту будет одновременно выдан доступ ко всем перечисленным инбаундам
# (например: основной Reality-инбаунд + резервный WS+TLS для плохих сетей)
INBOUND_IDS=1
DEFAULT_LIMIT_IP=1

TELEGRAM_STARS_PROVIDER_TOKEN=

# ЮMoney (необязательно)
ENABLE_YOOMONEY=false
YOOMONEY_WALLET=4100118XXXXXXXXX
YOOMONEY_SECRET=your_yoomoney_notification_secret
WEBHOOK_HOST=https://yourdomain.com

ADMIN_IDS=123456789,987654321

SUPPORT_USERNAME=your_support_username
SUPPORT_EMAIL=

NOTIFY_7_DAYS=true
NOTIFY_3_DAYS=true
NOTIFY_1_DAY=true

DISABLE_EXPIRED_USERS=true
