BOT_TOKEN=your_bot_token_here

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=vpnbot
POSTGRES_USER=vpnbot
POSTGRES_PASSWORD=your_secure_password

THREEXUI_URL=https://your-server.com:2053
THREEXUI_USERNAME=admin
THREEXUI_PASSWORD=your_3xui_password
THREEXUI_API_TOKEN=
THREEXUI_SUB_PORT=2096

# Один inbound: REALITY_INBOUND_ID=1
# Несколько inbound'ов (клиент создаётся сразу во всех, общий UUID/подписка):
REALITY_INBOUND_ID=1,2,3
DEFAULT_LIMIT_IP=1

# Лимит пользователей с активной платной подпиской. 0 = без ограничений.
# Продление уже действующей подписки лимитом не блокируется.
MAX_ACTIVE_SUBSCRIPTIONS=0

TELEGRAM_STARS_PROVIDER_TOKEN=

# Platega.io — СБП, банковские карты, криптовалюта (необязательно)
ENABLE_PLATEGA=false
PLATEGA_MERCHANT_ID=your_platega_merchant_id
PLATEGA_SECRET=your_platega_secret
# Код карточного эквайринга уточните у менеджера Platega/в ЛК
PLATEGA_METHOD_SBP=2
PLATEGA_METHOD_CARD=1
PLATEGA_METHOD_CRYPTO=13
WEBHOOK_HOST=https://yourdomain.com:9443

ADMIN_IDS=123456789,987654321

SUPPORT_USERNAME=your_support_username

NOTIFY_7_DAYS=true
NOTIFY_3_DAYS=true
NOTIFY_1_DAY=true

DISABLE_EXPIRED_USERS=true
